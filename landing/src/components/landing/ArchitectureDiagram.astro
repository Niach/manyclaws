---
---
<section id="architecture" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16 fade-in">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">
        How traffic <span style="color: #06B6D4;">flows.</span>
      </h2>
      <p class="mt-4 text-gray-400 max-w-xl mx-auto">
        From the internet to your agent's pod, every hop is authenticated and isolated.
      </p>
    </div>

    <div class="fade-in glass p-8 rounded-2xl glow-cyan overflow-x-auto">
      <div class="font-mono text-sm min-w-[600px]">
        <!-- Internet -->
        <div class="flex items-center gap-3 mb-4">
          <div class="px-4 py-2 rounded-lg text-white font-semibold" style="background: linear-gradient(135deg, #8B5CF6, #7C3AED);">
            🌐 Internet
          </div>
          <div class="flex-1 border-t-2 border-dashed" style="border-color: #8B5CF640;"></div>
        </div>

        <!-- Cloudflare -->
        <div class="ml-8 flex items-center gap-3 mb-4">
          <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          <div class="px-4 py-2 rounded-lg" style="background: rgba(245, 158, 11, 0.15); border: 1px solid rgba(245, 158, 11, 0.3); color: #FBBF24;">
            🛡️ Cloudflare Access <span class="text-xs text-gray-500">(zero-trust OTP)</span>
          </div>
        </div>

        <!-- Tunnel -->
        <div class="ml-16 flex items-center gap-3 mb-4">
          <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          <div class="px-4 py-2 rounded-lg" style="background: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.3); color: #67E8F9;">
            🚇 Cloudflare Tunnel <span class="text-xs text-gray-500">(no open ports)</span>
          </div>
        </div>

        <!-- Traefik -->
        <div class="ml-24 flex items-center gap-3 mb-6">
          <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          <div class="px-4 py-2 rounded-lg" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); color: #6EE7B7;">
            🔀 Traefik Ingress <span class="text-xs text-gray-500">(IngressRoute CRDs)</span>
          </div>
        </div>

        <!-- Namespace boxes -->
        <div class="ml-32 grid grid-cols-3 gap-3">
          <div class="p-3 rounded-lg text-center" style="background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.25);">
            <div class="text-xs font-bold" style="color: #A78BFA;">agent-&lt;name&gt;</div>
            <div class="text-[10px] text-gray-500 mt-1">Your AI Agent</div>
          </div>
          <div class="p-3 rounded-lg text-center" style="background: rgba(236, 72, 153, 0.1); border: 1px solid rgba(236, 72, 153, 0.25);">
            <div class="text-xs font-bold" style="color: #F472B6;">manyclaws-system</div>
            <div class="text-[10px] text-gray-500 mt-1">Controller + Tunnel</div>
          </div>
          <div class="p-3 rounded-lg text-center" style="background: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.25);">
            <div class="text-xs font-bold" style="color: #67E8F9;">friend-&lt;name&gt;</div>
            <div class="text-[10px] text-gray-500 mt-1">Friend Workloads</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
