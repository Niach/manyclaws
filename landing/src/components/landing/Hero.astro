---
---
<section class="relative pt-32 pb-20 overflow-hidden">
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(139,92,246,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(139,92,246,0.5) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <!-- Gradient orbs -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 rounded-full opacity-20 blur-3xl" style="background: radial-gradient(circle, #8B5CF6, transparent);"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 rounded-full opacity-15 blur-3xl" style="background: radial-gradient(circle, #06B6D4, transparent);"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium mb-6" style="background: rgba(139, 92, 246, 0.15); color: #b9a0fa; border: 1px solid rgba(139, 92, 246, 0.3);">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      Built on OpenClaw
    </div>

    <!-- Pitch -->
    <h1 class="text-4xl sm:text-5xl font-black leading-tight tracking-tight text-white">
      Turn your OpenClaw into a
      <span style="background: linear-gradient(135deg, #8B5CF6, #06B6D4, #EC4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        playground for your friends.
      </span>
    </h1>

    <p class="mt-5 text-lg text-gray-400 max-w-2xl mx-auto">
      Multi-agent namespaces, a friend portal, and vibe-coding &mdash;
      on the k3s box you already have.
    </p>

    <!-- Install command -->
    <div class="mt-10 glass glow-purple rounded-xl overflow-hidden text-left max-w-2xl mx-auto">
      <div class="flex items-center justify-between px-4 py-2 border-b border-white/5" style="background: rgba(15, 15, 35, 0.8);">
        <span class="text-xs text-gray-500 font-mono">Quick start</span>
        <button id="copy-btn" class="text-xs text-gray-500 hover:text-white transition-colors cursor-pointer flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <span id="copy-text">Copy</span>
        </button>
      </div>
      <div class="p-5 font-mono text-sm" style="background: #0d0d1a;">
        <span style="color: #10B981;">$</span>
        <span class="text-gray-300"> git clone https://github.com/niach/manyclaws</span><br/>
        <span style="color: #10B981;">$</span>
        <span class="text-gray-300"> cd manyclaws && kubectl apply -f manifests/</span>
      </div>
    </div>

    <!-- Links -->
    <div class="mt-6 flex justify-center gap-6">
      <a href="/docs/getting-started/install/" class="inline-flex items-center gap-2 text-sm font-semibold transition-colors" style="color: #b9a0fa;">
        Read the install guide
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="/docs/" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">
        Browse the docs
      </a>
    </div>
  </div>

  <script>
    document.getElementById('copy-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText('git clone https://github.com/niach/manyclaws && cd manyclaws && kubectl apply -f manifests/');
      const el = document.getElementById('copy-text');
      if (el) { el.textContent = 'Copied!'; setTimeout(() => el.textContent = 'Copy', 2000); }
    });
  </script>
</section>
